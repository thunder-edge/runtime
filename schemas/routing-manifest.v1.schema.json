{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thunder.dev/schemas/routing-manifest.v1.schema.json",
  "title": "Edge Runtime Global Routing Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifestVersion", "routes"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "manifestVersion": {
      "type": "integer",
      "const": 1
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["host", "path", "targetFunction"],
        "properties": {
          "host": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^/"
          },
          "targetFunction": {
            "$ref": "https://thunder.dev/schemas/base/common.schema.json#/$defs/functionName"
          }
        }
      }
    }
  }
}